{
	"collections": [
		{
			"stac_version": "1.0.0",
			"stac_extensions": [
        "https://stac-extensions.github.io/eo/v2.0.0/schema.json",
        "https://stac-extensions.github.io/pointcloud/v2.0.0/schema.json",
        "https://stac-extensions.github.io/video/v1.0.0/schema.json",
        "https://stac-extensions.github.io/processing/v1.2.0/schema.json",
        "https://stac-extensions.github.io/sar/v1.3.0/schema.json",
        "https://stac-extensions.github.io/view/v1.1.0/schema.json"
      ],
			"type": "Collection",
			"id": "{collectionId}",
			"title": "Esri Geoportal Server Metadata",
			"description": "STAC API Powered by Esri Geoportal Server Catalog",
			"license": "Apache-2.0",
			"extent": {
				"spatial": {
					"bbox": [
						[
							-180.0,
							 -90.0, 
							 180.0,
							  90.0
						]
					]
				},
				"temporal": {
					"interval": [
						[
							"2018-06-23T00:00:00Z",
							"2023-09-26T13:44:56Z"
						]
					]
				}
			},
			"item_assets": {
				"thumbnail": {
					"type": "image/jpeg",
					"title": "Thumbnail",
					"description": "A medium sized thumbnail",
					"roles": [
						"thumbnail"
					]
				},
				"metadata": {
					"type": "mtl",
					"roles": [
						"metadata"
					],
					"title": "Original Metadata",
					"description": "The original metadata file"
				}
			}
    }
  ],
  "links": [
    {
      "rel": "self",
      "type": "application/json",
      "title": "Link to the Metadata collection",
      "href": "{url}/collections"
    },
    {
      "rel": "root",
      "type": "application/json",
      "title": "Link to STAC entry point",
      "href": "{url}"
    },
    {
      "rel": "parent",
      "type": "application/json",
      "title": "Link to STAC entry point",
      "href": "{url}"
    }
  ]
}